#!/usr/bin/env ruby

require "fileutils"
require "brut"
APP_PATH = File.join(File.dirname($0),"..","app","src")
$: << APP_PATH
require "cli/downloads"

runner = Brut::CLI::Runner.new(
  DownloadsCLI.new,
  stdout: $stdout,
  stderr: $stderr,
  stdin: $stdin,
  project_root: Pathname(FileUtils.pwd),
)
exit runner.run!(ARGV,ENV)


